{
  "tunnels": [
    {
      "id": "example_8080",
      "name": "示例 8080",
      "command": "ssh -N -o ExitOnForwardFailure=yes -L 8080:127.0.0.1:8080 user@example.com",
      "enabled_on_start": false,
      "auto_retry": {
        "enabled": true,
        "max_attempts": 0,
        "initial_delay_seconds": 3,
        "max_delay_seconds": 60,
        "reset_after_seconds": 300
      }
    }
  ]
}
